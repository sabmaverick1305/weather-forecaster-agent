# OpenWeatherMap — https://openweathermap.org/api
OWM_API_KEY=your_owm_api_key_here

# AWS credentials (local dev only; use IAM task role on ECS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SESSION_TOKEN=

# Bedrock AgentCore Runtime ARN (set after running infrastructure/create_agentcore_runtime.py)
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:runtime/weather-agent-xxx

# MCP server URL (agent reads this to connect to tools)
MCP_SERVER_URL=http://mcp-server:8000/mcp

# Local dev override: backend calls agent HTTP directly instead of boto3
LOCAL_AGENT_URL=http://agent:8080/invocations

# Bedrock model
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
